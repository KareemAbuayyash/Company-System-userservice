<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand" href="@Url.Action("Index", "Home")">
            <i class="fas fa-building me-2"></i>
            Company System
        </a>
        
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")" 
                       href="@Url.Action("Index", "Home")">
                        <i class="fas fa-home me-1"></i>
                        Home
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Department" ? "active" : "")" 
                       href="@Url.Action("Index", "Department")">
                        <i class="fas fa-building me-1"></i>
                        Departments
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "MainPageContent" ? "active" : "")" 
                       href="@Url.Action("Index", "MainPageContent")">
                        <i class="fas fa-edit me-1"></i>
                        CMS
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Note" ? "active" : "")" 
                       href="@Url.Action("Index", "Note")">
                        <i class="fas fa-sticky-note me-1"></i>
                        Notes
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "About" ? "active" : "")" 
                       href="@Url.Action("About", "Home")">
                        <i class="fas fa-info-circle me-1"></i>
                        About
                    </a>
                </li>
            </ul>

            <!-- User section -->
            @if (User.Identity?.IsAuthenticated == true)
            {
                <ul class="navbar-nav">
                    <li class="nav-item dropdown user-dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fas fa-user me-1"></i>
                            @(User.FindFirst("FirstName")?.Value ?? "User") @(User.FindFirst("LastName")?.Value ?? "")
                            <span class="user-role-badge ms-1">@(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Employee")</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                            <li>
                                <h6 class="dropdown-header">
                                    <i class="fas fa-envelope me-1"></i>
                                    @(User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "")
                                </h6>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="dropdown-item text-danger logout-btn" onclick="return confirm('Are you sure you want to logout?')">
                                        <i class="fas fa-sign-out-alt me-2"></i>
                                        Logout
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </li>
                </ul>
            }
        </div>
    </div>
</nav>
